package com.citi.rulefabricator.export.util;

import java.util.HashSet;
import java.util.Set;

/**
 * SXSSFWorkbook-safe Excel sheet name generator.
 * One instance MUST be used per workbook.
 */
public class ExcelSheetNameGenerator {

    private static final int MAX_LENGTH = 31;
    private static final String ILLEGAL_CHARS_REGEX = "[:\\\\/?*\\[\\]]";

    private final Set<String> usedNames = new HashSet<>();

    /**
     * Generate a unique, Excel-safe sheet name.
     */
    public String next(String baseName) {

        String normalized = normalize(baseName);
        String candidate = normalized;
        int counter = 1;

        while (usedNames.contains(candidate.toLowerCase())) {
            String suffix = "_" + counter++;
            int maxBaseLength = MAX_LENGTH - suffix.length();
            candidate = normalized.substring(
                    0, Math.min(normalized.length(), maxBaseLength)
            ) + suffix;
        }

        usedNames.add(candidate.toLowerCase());
        return candidate;
    }

    private String normalize(String name) {
        if (name == null || name.isBlank()) {
            return "Sheet";
        }

        name = name.trim();
        name = name.replaceAll(ILLEGAL_CHARS_REGEX, "_");

        return name.length() > MAX_LENGTH
                ? name.substring(0, MAX_LENGTH)
                : name;
    }
}





// ======================= EXCEL TEMPLATE VALIDATOR =======================

public class ExcelTemplateValidator extends
        ChainableBaseConstraintValidator<TableConstraintInputDTO,
                                         ExcelTemplateConfig,
                                         TypeWiseConstraintFailures>
        implements ConstraintContextAware {

    private ConstraintContext context;

    public ExcelTemplateValidator(ExcelTemplateConfig config) {
        super(config);
    }

    @Override
    public void setContext(ConstraintContext context) {
        this.context = context;
    }

    @Override
    public ConstraintContext getContext() {
        return context;
    }

    @Override
    public void validate(TableConstraintInputDTO object,
                         TypeWiseConstraintFailures failureContainer) {

        ExcelTemplateConfig config = getConfig();

        if (config == null || config.getSourceConfig() == null) {
            throw new IllegalArgumentException("Invalid ExcelTemplateConfig");
        }

        SourceConfig sourceConfig = config.getSourceConfig();

        SourceValidatorStrategy strategy = sourceConfig.getStrategy();

        strategy.validate(sourceConfig, object, failureContainer);
    }
}



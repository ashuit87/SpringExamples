// ======================= ENUM =======================

public enum SourceType {
    NAS,
    API;

    public static SourceType from(String value) {
        return SourceType.valueOf(value.toUpperCase());
    }
}


// ======================= BASE CONFIG =======================

public abstract class SourceConfig {
    public abstract SourceValidatorStrategy getStrategy();
}


// ======================= NAS CONFIG =======================

public class NasSourceConfig extends SourceConfig {

    private String filePath;
    private String fileType;

    @Override
    public SourceValidatorStrategy getStrategy() {
        return new NasSourceValidatorStrategy();
    }

    public String getFilePath() {
        return filePath;
    }

    public String getFileType() {
        return fileType;
    }
}


// ======================= API CONFIG =======================

public class APISourceConfig extends SourceConfig {

    private String url;
    private String method;

    @Override
    public SourceValidatorStrategy getStrategy() {
        return new ApiSourceValidatorStrategy();
    }

    public String getUrl() {
        return url;
    }

    public String getMethod() {
        return method;
    }
}


// ======================= MAIN CONFIG =======================

public class ExcelTemplateConfig extends RowConstraintConfig {

    private SourceType sourceType;
    private SourceConfig sourceConfig;

    public ExcelTemplateConfig(String msgKey,
                               String sourceType,
                               SourceConfig sourceConfig) {
        super(msgKey);
        this.sourceType = SourceType.from(sourceType);
        this.sourceConfig = sourceConfig;
    }

    public SourceType getSourceType() {
        return sourceType;
    }

    public SourceConfig getSourceConfig() {
        return sourceConfig;
    }
}


// ======================= STRATEGY INTERFACE =======================

public interface SourceValidatorStrategy<T extends SourceConfig> {

    void validate(T config,
                  TableConstraintInputDTO input,
                  TypeWiseConstraintFailures failureContainer);
}


// ======================= NAS STRATEGY =======================

public class NasSourceValidatorStrategy
        implements SourceValidatorStrategy<NasSourceConfig> {

    @Override
    public void validate(NasSourceConfig config,
                         TableConstraintInputDTO input,
                         TypeWiseConstraintFailures failureContainer) {

        System.out.println("Validating NAS: " + config.getFilePath());
    }
}


// ======================= API STRATEGY =======================

public class ApiSourceValidatorStrategy
        implements SourceValidatorStrategy<APISourceConfig> {

    @Override
    public void validate(APISourceConfig config,
                         TableConstraintInputDTO input,
                         TypeWiseConstraintFailures failureContainer) {

        System.out.println("Validating API: " + config.getUrl());
    }
}


// ======================= VALIDATOR =======================

@Override
public void validate(TableConstraintInputDTO object,
                     TypeWiseConstraintFailures failureContainer) {

    ExcelTemplateConfig config = (ExcelTemplateConfig) getConfig();

    SourceConfig sourceConfig = config.getSourceConfig();

    SourceValidatorStrategy strategy = sourceConfig.getStrategy();

    strategy.validate(sourceConfig, object, failureContainer);
}

import com.fasterxml.jackson.annotation.JsonCreator;
import com.fasterxml.jackson.annotation.JsonProperty;

public class ExcelTemplateConfig extends RowConstraintConfig {

    private String sourceType;
    private NasSourceConfig nasSourceConfig;
    private APISourceConfig apiSourceConfig;

    @JsonCreator
    public ExcelTemplateConfig(
            @JsonProperty("msgKey") String msgKey,
            @JsonProperty("sourceType") String sourceType,
            @JsonProperty("nasSourceConfig") NasSourceConfig nasSourceConfig,
            @JsonProperty("apiSourceConfig") APISourceConfig apiSourceConfig
    ) {
        super(msgKey);
        this.sourceType = sourceType;
        this.nasSourceConfig = nasSourceConfig;
        this.apiSourceConfig = apiSourceConfig;
    }

    public String getSourceType() {
        return sourceType;
    }

    public void setSourceType(String sourceType) {
        this.sourceType = sourceType;
    }

    public NasSourceConfig getNasSourceConfig() {
        return nasSourceConfig;
    }

    public void setNasSourceConfig(NasSourceConfig nasSourceConfig) {
        this.nasSourceConfig = nasSourceConfig;
    }

    public APISourceConfig getApiSourceConfig() {
        return apiSourceConfig;
    }

    public void setApiSourceConfig(APISourceConfig apiSourceConfig) {
        this.apiSourceConfig = apiSourceConfig;
    }
}

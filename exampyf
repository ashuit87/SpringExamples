@Service("postWorkflowApiExecutor")
public class PostWorkflowApiExecutor implements PostWorkflowProcessService {

    private static final Logger LOGGER = LoggerFactory.getLogger(PostWorkflowApiExecutor.class);

    private static final String API_RESPONSE = "apiResponse";

    private final RuleDefService ruleDefService;
    private final ObjectMapper objectMapper;
    private final TaskService taskService;
    private final RestTemplate restTemplate;
    private final ApiRequestBuilder apiRequestBuilder;
    private final ApplicationApiRegistryService applicationApiRegistryService;

    public PostWorkflowApiExecutor(RuleDefService ruleDefService,
                                   ApiRequestBuilder apiRequestBuilder,
                                   RestTemplate restTemplate,
                                   TaskService taskService,
                                   ObjectMapper objectMapper,
                                   ApplicationApiRegistryService applicationApiRegistryService) {

        this.ruleDefService = ruleDefService;
        this.apiRequestBuilder = apiRequestBuilder;
        this.restTemplate = restTemplate;
        this.taskService = taskService;
        this.objectMapper = objectMapper;
        this.applicationApiRegistryService = applicationApiRegistryService;
    }

    // ========================= EXECUTE =========================

    @Override
    public void execute(Map<String, Object> executionConfig) {

        long mapDefId = (Long) executionConfig.get(ApplicationConstants.MAP_DEF_ID);
        String createdBy = (String) executionConfig.get(ApplicationConstants.CREATED_BY);
        long masterId = (Long) executionConfig.get(ApplicationConstants.MASTER_ID);

        RuleDef ruleDef = ruleDefService.findOneByMapId(mapDefId);

        ApiExecutorConfig apiExecutorConfig = objectMapper.convertValue(
                ruleDef.getProcessWorkflowConfig().getConfig(),
                ApiExecutorConfig.class
        );

        List<ApiConfig> apiCallSequence = apiExecutorConfig.getApiCallSequence();
        String executionMode = apiExecutorConfig.getExecutionMode();

        // 🔥 NEW FLAG
        boolean isCheckForDbSyncWait = apiExecutorConfig.isCheckForDbSyncWait();

        UserDTO user = new UserDTO.UserBuilder(createdBy)
                .addPermissionManager(PermissionDTO.APPROVAL_TYPE.AUTO)
                .build();

        TaskDTO task = taskService.createNewTask(
                TaskDTO.TaskType.EXTERNAL_API_CALL,
                TaskDTO.TaskCategory.MAP_DEF,
                mapDefId,
                null,
                TaskDTO.TaskSource.ONDEMAND,
                user,
                TaskDTO.TaskStatus.IN_PROGRESS,
                masterId
        );

        // ========================= FLOW CONTROL =========================

        if (isCheckForDbSyncWait) {

            LOGGER.info("DB Sync wait enabled. Waiting before API execution...");

            checkForDBSyncWithStatus(masterId, apiExecutorConfig.getDbSyncWaitTimeInMinutes())
                    .thenAccept(isCompleted -> {

                        if (Boolean.TRUE.equals(isCompleted)) {

                            LOGGER.info("DB Sync completed. Proceeding with API execution...");

                            triggerExecution(ruleDef, apiCallSequence, executionConfig, task, user, executionMode);

                        } else {

                            LOGGER.error("DB Sync failed. Skipping API execution.");

                            taskService.updateTaskForFailureWithDtlMsg(
                                    task.get_id(),
                                    "DB Sync not completed",
                                    null,
                                    user
                            );
                        }

                    })
                    .exceptionally(ex -> {

                        LOGGER.error("Exception while waiting for DB Sync", ex);

                        taskService.updateTaskForFailureWithDtlMsg(
                                task.get_id(),
                                "Exception while waiting for DB Sync",
                                ex.getMessage(),
                                user
                        );

                        return null;
                    });

        } else {

            LOGGER.info("DB Sync wait disabled. Directly executing APIs...");

            triggerExecution(ruleDef, apiCallSequence, executionConfig, task, user, executionMode);
        }
    }

    // ========================= EXECUTION SWITCH =========================

    private void triggerExecution(RuleDef ruleDef,
                                  List<ApiConfig> apiCallSequence,
                                  Map<String, Object> executionConfig,
                                  TaskDTO task,
                                  UserDTO user,
                                  String executionMode) {

        if ("PARALLEL".equalsIgnoreCase(executionMode)) {
            executeInParallel(ruleDef, apiCallSequence, executionConfig, task, user);
        } else {
            executeSequentially(ruleDef, apiCallSequence, executionConfig, task, user);
        }
    }

    // ========================= SEQUENTIAL =========================

    private void executeSequentially(RuleDef ruleDef,
                                     List<ApiConfig> apiCallSequence,
                                     Map<String, Object> executionConfig,
                                     TaskDTO task,
                                     UserDTO user) {

        CompletableFuture<Void> chain = CompletableFuture.completedFuture(null);

        for (ApiConfig apiConfig : apiCallSequence) {
            chain = chain.thenCompose(v ->
                    buildApiPayloadAndCallService(ruleDef, apiConfig, executionConfig, task, user)
                            .thenApply(res -> null)
            );
        }

        chain.exceptionally(ex -> {
            LOGGER.error("Execution stopped (SEQUENTIAL mode)", ex);
            return null;
        });
    }

    // ========================= PARALLEL =========================

    private void executeInParallel(RuleDef ruleDef,
                                   List<ApiConfig> apiCallSequence,
                                   Map<String, Object> executionConfig,
                                   TaskDTO task,
                                   UserDTO user) {

        List<CompletableFuture<Void>> futures = apiCallSequence.stream()
                .map(apiConfig ->
                        buildApiPayloadAndCallService(ruleDef, apiConfig, executionConfig, task, user)
                                .thenApply(res -> null)
                                .exceptionally(ex -> {
                                    LOGGER.error("API FAILED (parallel): {}", apiConfig.getName(), ex);
                                    return null;
                                })
                )
                .collect(Collectors.toList());

        CompletableFuture.allOf(futures.toArray(new CompletableFuture[0]))
                .thenRun(() -> LOGGER.info("All APIs executed (PARALLEL mode)"));
    }

    // ========================= CORE =========================

    public CompletableFuture<ResponseEntity<Object>> buildApiPayloadAndCallService(
            RuleDef ruleDef,
            ApiConfig apiConfig,
            Map<String, Object> executionConfig,
            TaskDTO task,
            UserDTO user) {

        List<Long> seqs = (List<Long>) executionConfig.get(ApplicationConstants.SEQ);
        long masterId = (Long) executionConfig.get(ApplicationConstants.MASTER_ID);

        String apiUrl = buildUrl(apiConfig);

        Map<String, Object> requestMetaData =
                ApiUtil.getRequestMetaDataInMap(masterId, ruleDef.getMapDefId(), ruleDef.getMapName(), seqs);

        // RECORD LEVEL
        if (apiConfig.isRecordLevelScope()) {

            CompletableFuture<Void> seqChain = CompletableFuture.completedFuture(null);

            for (Long seq : seqs) {

                seqChain = seqChain.thenCompose(v -> {

                    ApiRequestPayloadDTO payload =
                            prepareRequestObject(apiConfig, requestMetaData, Arrays.asList(seq));

                    return postRequest(apiUrl, payload)
                            .thenCompose(response -> {

                                if (response.getStatusCode().is2xxSuccessful()) {
                                    processApiResponse(task, user).accept(response);
                                    return CompletableFuture.completedFuture(null);
                                } else {
                                    return CompletableFuture.failedFuture(
                                            new RuntimeException("Failure at seq: " + seq)
                                    );
                                }
                            });
                });
            }

            return seqChain.thenApply(v -> null);
        }

        // NON RECORD LEVEL
        ApiRequestPayloadDTO payload =
                prepareRequestObject(apiConfig, requestMetaData, seqs);

        return postRequest(apiUrl, payload)
                .thenCompose(response -> {

                    if (response.getStatusCode().is2xxSuccessful()) {
                        processApiResponse(task, user).accept(response);
                        return CompletableFuture.completedFuture(response);
                    } else {
                        return CompletableFuture.failedFuture(new RuntimeException("API failure"));
                    }
                });
    }

    // ========================= API CALL =========================

    public CompletableFuture<ResponseEntity<Object>> postRequest(String apiUrl,
                                                                  ApiRequestPayloadDTO payload) {

        return CompletableFuture.supplyAsync(() -> {
            try {
                HttpHeaders headers = new HttpHeaders();
                headers.setContentType(MediaType.APPLICATION_JSON);

                HttpEntity<?> request =
                        (payload != null)
                                ? new HttpEntity<>(payload, headers)
                                : new HttpEntity<>(headers);

                return restTemplate.exchange(apiUrl, HttpMethod.POST, request, Object.class);

            } catch (Exception e) {
                throw new RuntimeException(e);
            }
        });
    }

    // ========================= HELPERS =========================

    public ApiRequestPayloadDTO prepareRequestObject(ApiConfig apiConfig,
                                                     Map<String, Object> requestMetaData,
                                                     List<Long> seqs) {
        return apiRequestBuilder.buildRequestPayload(apiConfig, requestMetaData, seqs);
    }

    private String buildUrl(ApiConfig apiConfig) {
        return applicationApiRegistryService.resolveUrl(
                apiConfig.getUrlConfig().getDomain(),
                apiConfig.getUrlConfig().getService(),
                apiConfig.getUrlConfig().getOperation()
        );
    }

    private Consumer<ResponseEntity<Object>> processApiResponse(TaskDTO task,
                                                               UserDTO user) {
        return response -> {
            Map<String, Object> output = new HashMap<>();
            output.put(API_RESPONSE, response.getBody());

            task.setOutput(output);
            task.setStatus(TaskDTO.TaskStatus.COMPLETED);

            taskService.update(task, user);
        };
    }

    // ========================= DB SYNC =========================

    public CompletableFuture<Boolean> checkForDBSyncWithStatus(long masterId, long timeoutInMinutes) {

        return CompletableFuture.supplyAsync(() -> {

            long startTime = System.currentTimeMillis();
            long timeoutMillis = timeoutInMinutes * 60 * 1000;

            while (true) {
                try {

                    if (System.currentTimeMillis() - startTime > timeoutMillis) {
                        throw new RuntimeException("DB Sync timeout");
                    }

                    Thread.sleep(10000);

                    Document doc = dbSyncDAOMongoImpl.findOneByMasterId(masterId);

                    if (doc != null) {
                        DBSyncQueueItemDTO dto =
                                mongoUtil.documentToPojo(doc, DBSyncQueueItemDTO.class);

                        String status = dto.getStatus().name();

                        if ("COMPLETED".equalsIgnoreCase(status)) return true;
                        if ("FAILED".equalsIgnoreCase(status)
                                || "COMPLETED_WITH_ERRORS".equalsIgnoreCase(status)) return false;
                    }

                } catch (InterruptedException e) {
                    Thread.currentThread().interrupt();
                    throw new RuntimeException(e);
                }
            }
        });
    }
}

package com.citi.rulefabricator.constraints.impl.data.table.template;

import com.citi.rulefabricator.constraints.impl.data.table.template.config.*;
import com.fasterxml.jackson.annotation.*;
import org.springframework.stereotype.*;
import org.springframework.beans.factory.annotation.*;
import org.springframework.http.*;
import org.springframework.web.client.RestTemplate;

import java.io.File;
import java.util.*;
import java.util.function.Function;
import java.util.stream.Collectors;

// ====================== ENUM ======================
public enum SourceType {
    NAS,
    API;

    public static SourceType from(String value) {
        return SourceType.valueOf(value.toUpperCase());
    }
}

// ====================== BASE CONFIG ======================
@JsonTypeInfo(
        use = JsonTypeInfo.Id.NAME,
        include = JsonTypeInfo.As.PROPERTY,
        property = "sourceType"
)
@JsonSubTypes({
        @JsonSubTypes.Type(value = NasSourceConfig.class, name = "NAS"),
        @JsonSubTypes.Type(value = ApiSourceConfig.class, name = "API")
})
abstract class BaseSourceConfig {
    public abstract SourceType getType();
}

// ====================== NAS CONFIG ======================
@JsonTypeName("NAS")
class NasSourceConfig extends BaseSourceConfig {

    private String filePath;

    @Override
    public SourceType getType() {
        return SourceType.NAS;
    }

    public String getFilePath() {
        return filePath;
    }

    public void setFilePath(String filePath) {
        this.filePath = filePath;
    }
}

// ====================== API CONFIG ======================
@JsonTypeName("API")
class ApiSourceConfig extends BaseSourceConfig {

    private String applicationId;
    private String moduleName;
    private String endpointName;
    private String payloadProviderClass;

    @Override
    public SourceType getType() {
        return SourceType.API;
    }

    public String getApplicationId() { return applicationId; }
    public String getModuleName() { return moduleName; }
    public String getEndpointName() { return endpointName; }
    public String getPayloadProviderClass() { return payloadProviderClass; }
}

// ====================== TEMPLATE SOURCE ======================
interface TemplateSource<T extends BaseSourceConfig> {

    SourceType getType();

    File fetchTemplate(T config, ConstraintContext context);
}

// ====================== NAS SOURCE ======================
@Component
class NASSource implements TemplateSource<NasSourceConfig> {

    @Override
    public SourceType getType() {
        return SourceType.NAS;
    }

    @Override
    public File fetchTemplate(NasSourceConfig config, ConstraintContext context) {

        if (config.getFilePath() == null) {
            throw new IllegalArgumentException("File path is null");
        }

        File file = new File(config.getFilePath());

        if (!file.exists()) {
            throw new RuntimeException("File not found: " + config.getFilePath());
        }

        return file;
    }
}

// ====================== API SOURCE ======================
@Component
class APISource implements TemplateSource<ApiSourceConfig> {

    @Autowired
    private RequestBuilderFactory requestBuilderFactory;

    @Autowired
    private RestTemplate restTemplate;

    @Autowired
    private FileUtil fileUtil;

    @Override
    public SourceType getType() {
        return SourceType.API;
    }

    @Override
    public File fetchTemplate(ApiSourceConfig config, ConstraintContext context) {

        BaseRequestBuilder builder =
                requestBuilderFactory.getProvider(config.getPayloadProviderClass());

        ResponseEntity<byte[]> response =
                restTemplate.exchange(
                        config.getEndpointName(),
                        HttpMethod.POST,
                        builder.buildPayload(context.getInput()),
                        byte[].class
                );

        String filePath = fileUtil.writeToFile(
                response.getBody(),
                context.getMasterRequestId().toString()
        );

        return new File(filePath);
    }
}

// ====================== PROVIDER ======================
@Component
class TemplateSourceProvider {

    private final Map<SourceType, TemplateSource<?>> sourceMap;

    @Autowired
    public TemplateSourceProvider(List<TemplateSource<?>> sources) {
        this.sourceMap = sources.stream()
                .collect(Collectors.toMap(
                        TemplateSource::getType,
                        Function.identity()
                ));
    }

    @SuppressWarnings("unchecked")
    public <T extends BaseSourceConfig> TemplateSource<T> get(SourceType type) {
        return (TemplateSource<T>) sourceMap.get(type);
    }
}

// ====================== SERVICE ======================
@Service
class TemplateService {

    @Autowired
    private TemplateSourceProvider provider;

    public <T extends BaseSourceConfig> File getTemplate(
            T config,
            ConstraintContext context) {

        return provider.get(config.getType())
                       .fetchTemplate(config, context);
    }
}

// ====================== STRATEGY ======================
interface SourceValidatorStrategy<T extends BaseSourceConfig> {

    void validate(
            T config,
            TableConstraintInputDTO input,
            TypeWiseConstraintFailures failureContainer,
            ConstraintContext context
    );
}

// ====================== FACTORY ======================
@Component
class SourceValidatorStrategyFactory {

    private final Map<String, SourceValidatorStrategy<? extends BaseSourceConfig>> strategies;

    public SourceValidatorStrategyFactory(
            Map<String, SourceValidatorStrategy<? extends BaseSourceConfig>> strategies) {
        this.strategies = strategies;
    }

    @SuppressWarnings("unchecked")
    public <T extends BaseSourceConfig> SourceValidatorStrategy<T> getStrategy(SourceType type) {

        SourceValidatorStrategy<?> strategy = strategies.get(type.name());

        if (strategy == null) {
            throw new IllegalArgumentException("No strategy found for " + type);
        }

        return (SourceValidatorStrategy<T>) strategy;
    }
}

// ====================== NAS VALIDATOR ======================
@Component("NAS")
class NasSourceValidator implements SourceValidatorStrategy<NasSourceConfig> {

    @Autowired
    private TemplateService templateService;

    @Autowired
    private ExcelLockedCellValidator excelLockedCellValidator;

    @Override
    public void validate(
            NasSourceConfig config,
            TableConstraintInputDTO input,
            TypeWiseConstraintFailures failureContainer,
            ConstraintContext context) {

        File templateFile = templateService.getTemplate(config, context);

        File uploadedFile = getUploadedFile(input, context);

        excelLockedCellValidator.compareLockedCells(uploadedFile, templateFile);
    }

    private File getUploadedFile(TableConstraintInputDTO input, ConstraintContext context) {
        return new File("uploaded.xlsx"); // replace with your logic
    }
}


import org.springframework.beans.factory.annotation.Autowired;
import java.util.Map;

public class ExcelTemplateValidator
        extends ChainableBaseConstraintValidator<TableConstraintInputDTO, ExcelTemplateConfig, TypeWiseConstraintFailures>
        implements ConstraintContextAware {

    private ConstraintContext context;

    @Autowired
    private Map<String, SourceValidatorStrategy> strategyMap;

    public ExcelTemplateValidator(ExcelTemplateConfig config) {
        super(config);
    }

    @Override
    public void setContext(ConstraintContext context) {
        this.context = context;
    }

    @Override
    public ConstraintContext getContext() {
        return context;
    }

    @Override
    public void validate(TableConstraintInputDTO object,
                         TypeWiseConstraintFailures failureContainer) {

        ExcelTemplateConfig config = (ExcelTemplateConfig) getConfig();

        String key = config.getSourceType().name();

        SourceValidatorStrategy strategy = strategyMap.get(key);

        if (strategy == null) {
            throw new IllegalArgumentException("Unsupported sourceType: " + key);
        }

        strategy.validate(object, failureContainer, config, context);
    }
}





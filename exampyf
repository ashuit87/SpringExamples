public enum SourceType {
    NAS,
    API;

    public static SourceType from(String value) {
        return SourceType.valueOf(value.toUpperCase());
    }
}




import com.fasterxml.jackson.annotation.JsonCreator;
import com.fasterxml.jackson.annotation.JsonProperty;

public class ExcelTemplateConfig extends RowConstraintConfig {

    private SourceType sourceType;
    private NasSourceConfig nasSourceConfig;
    private APISourceConfig apiSourceConfig;

    @JsonCreator
    public ExcelTemplateConfig(
            @JsonProperty("msgKey") String msgKey,
            @JsonProperty("sourceType") String sourceType,
            @JsonProperty("nasSourceConfig") NasSourceConfig nasSourceConfig,
            @JsonProperty("apiSourceConfig") APISourceConfig apiSourceConfig
    ) {
        super(msgKey);
        this.sourceType = SourceType.from(sourceType);
        this.nasSourceConfig = nasSourceConfig;
        this.apiSourceConfig = apiSourceConfig;
    }

    public SourceType getSourceType() {
        return sourceType;
    }

    public NasSourceConfig getNasSourceConfig() {
        return nasSourceConfig;
    }

    public APISourceConfig getApiSourceConfig() {
        return apiSourceConfig;
    }
}




public class NasSourceConfig {

    private String filePath;
    private String fileType;

    public String getFilePath() {
        return filePath;
    }

    public String getFileType() {
        return fileType;
    }
}




public class APISourceConfig {

    private String url;
    private String method;

    public String getUrl() {
        return url;
    }

    public String getMethod() {
        return method;
    }
}



public interface SourceValidatorStrategy {

    SourceType getType();

    void validate(TableConstraintInputDTO input,
                  TypeWiseConstraintFailures failureContainer,
                  ExcelTemplateConfig config,
                  ConstraintContext context);
}


import org.springframework.stereotype.Component;

@Component("NAS")
public class NasSourceValidatorStrategy implements SourceValidatorStrategy {

    @Override
    public SourceType getType() {
        return SourceType.NAS;
    }

    @Override
    public void validate(TableConstraintInputDTO input,
                         TypeWiseConstraintFailures failureContainer,
                         ExcelTemplateConfig config,
                         ConstraintContext context) {

        NasSourceConfig nas = config.getNasSourceConfig();

        if (nas == null) {
            throw new IllegalArgumentException("NAS config missing");
        }

        // 👉 Your actual validation logic
        System.out.println("Validating NAS file: " + nas.getFilePath());
    }


}





import org.springframework.stereotype.Component;

@Component("API")

import com.fasterxml.jackson.annotation.JsonCreator;
import com.fasterxml.jackson.annotation.JsonProperty;

public class ExcelTemplateConfig extends RowConstraintConfig {

    private SourceType sourceType;
    private SourceConfig sourceConfig;

    @JsonCreator
    public ExcelTemplateConfig(
            @JsonProperty("msgKey") String msgKey,
            @JsonProperty("sourceType") String sourceType,
            @JsonProperty("sourceConfig") SourceConfig sourceConfig
    ) {
        super(msgKey);
        this.sourceType = SourceType.from(sourceType);
        this.sourceConfig = sourceConfig;

        validate();
    }

    private void validate() {
        if (sourceConfig == null) {
            throw new IllegalArgumentException("sourceConfig cannot be null");
        }

        if (!sourceType.equals(sourceConfig.getType())) {
            throw new IllegalArgumentException("Mismatch between sourceType and sourceConfig");
        }
    }

    public SourceType getSourceType() {
        return sourceType;
    }

    public SourceConfig getSourceConfig() {
        return sourceConfig;
    }
}


